# Public endpoint
DOMAIN=bot.example.com
APP_BIND_PORT=3020

# Application
NODE_ENV=production
PORT=3000
LOG_LEVEL=log
DATABASE_URL=file:/app/data/app.db

# Telegram webhook
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_DEV_POLLING=false
TELEGRAM_API_ROOT=

# Administrator
ADMIN_TELEGRAM_ID=

# Telegram Mini App session signing
MINI_APP_SESSION_SECRET=
MINI_APP_SESSION_TTL_SECONDS=7200
MINI_APP_INIT_DATA_MAX_AGE_SECONDS=600

# Protected booking decisions opened from a pending Google Calendar event.
PUBLIC_BASE_URL=https://bot.example.com
ADMIN_ACTION_SECRET=

# Google Calendar
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://bot.example.com/google/oauth/callback
GOOGLE_CALENDAR_ID=primary

# SMTP is optional until a provider is selected.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
