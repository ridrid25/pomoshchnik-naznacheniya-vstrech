# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=log

# Database
# SQLite-файл хранится вне контейнера; путь можно заменить в production-конфигурации.
DATABASE_URL=file:./data/app.db

# Telegram
# Оставьте пустым на Этапе 1. Реальный токен будет добавлен позднее только в локальный .env.
TELEGRAM_BOT_TOKEN=
# Необязательный секрет, которым Telegram подписывает webhook-запросы.
TELEGRAM_WEBHOOK_SECRET=
# Для простой локальной ручной проверки. В production оставьте false и используйте webhook.
TELEGRAM_DEV_POLLING=false
# Только для автоматических тестов с локальным mock API; в обычной среде оставьте пустым.
TELEGRAM_API_ROOT=

# Administrator
ADMIN_TELEGRAM_ID=

# Защищённые кнопки решения заявки из Google Calendar
PUBLIC_BASE_URL=
ADMIN_ACTION_SECRET=

# Google Calendar (будет настроено на Этапе 5)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_CALENDAR_ID=primary

# Email notifications (Nodemailer + SMTP/TLS)
# Заполните все четыре обязательных значения вместе. Пароль приложения храните только в .env.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
